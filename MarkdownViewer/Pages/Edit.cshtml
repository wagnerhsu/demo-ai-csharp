@page
@model EditPageModel
@{
    ViewData["Title"] = Model.IsNew ? "New File" : "Edit: " + Model.FilePath;
}

<div class="edit-layout">
    <div class="edit-header">
        <h2>@(Model.IsNew ? "New File" : "✏️ Edit File")</h2>
        <a href="@(Model.IsNew ? "/" : "/View?path=" + Uri.EscapeDataString(Model.FilePath))" class="btn btn-sm btn-outline">Cancel</a>
    </div>

    <form method="post" id="edit-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label for="filePath">File path (relative, e.g. <code>docs/guide.md</code>)</label>
            <input type="text" id="filePath" name="filePath" value="@Model.FilePath"
                   class="form-control" placeholder="filename.md" required />
        </div>

        <div class="form-group editor-wrapper">
            <label>Content</label>
            <textarea id="content" name="content">@Model.Content</textarea>
        </div>

        <div class="edit-actions">
            <button type="submit" class="btn">💾 Save</button>
            @if (!Model.IsNew)
            {
                <button type="button" class="btn btn-danger" onclick="confirmDelete()">🗑️ Delete</button>
            }
        </div>
    </form>

    @if (!Model.IsNew)
    {
        <form method="post" asp-page-handler="Delete" id="delete-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="filePath" value="@Model.FilePath" />
        </form>
    }

    @if (Model.Error is not null)
    {
        <div class="alert alert-error">@Model.Error</div>
    }
</div>

@section Scripts {
<script>
    const easyMDE = new EasyMDE({
        element: document.getElementById('content'),
        spellChecker: false,
        autosave: { enabled: false },
        toolbar: [
            'bold', 'italic', 'heading', '|',
            'quote', 'unordered-list', 'ordered-list', '|',
            'link', 'image', 'table', '|',
            'preview', 'side-by-side', 'fullscreen', '|',
            'guide'
        ]
    });

    function confirmDelete() {
        if (confirm('Delete this file? This cannot be undone.')) {
            document.getElementById('delete-form').submit();
        }
    }
</script>
}
