@page
@using MarkdownViewer.Services
@model IndexModel
@{
    ViewData["Title"] = "Files";
}

<div class="file-browser">
    <h2>📁 Markdown Files</h2>
    @if (!Model.Files.Any())
    {
        <p class="empty-hint">No markdown files found. <a href="/Edit">Create one</a>.</p>
    }
    else
    {
        <ul class="file-tree">
            @await Html.PartialAsync("_FileTree", Model.Files)
        </ul>
    }
</div>
