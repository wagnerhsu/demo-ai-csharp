@page "{id:int}"
@model PoetryManager.Web.Pages.Poems.DeleteModel
@{
    ViewData["Title"] = "删除确认";
}

<h2>删除诗词</h2>
<hr />

<div class="alert alert-warning">
    <strong>确认删除？</strong> 此操作不可撤销。
</div>

<div class="card mb-4" style="max-width: 600px">
    <div class="card-body">
        <h5 class="card-title">@Model.Poem.Title</h5>
        <p class="card-text text-muted">@Model.Poem.Author &nbsp;·&nbsp; @Model.Poem.Dynasty</p>
        <p class="card-text" style="white-space: pre-line">@Model.Poem.Content</p>
    </div>
</div>

<form method="post">
    <button type="submit" class="btn btn-danger">确认删除</button>
    <a asp-page="/Poems/Details" asp-route-id="@Model.Poem.Id" class="btn btn-secondary ms-2">取消</a>
</form>
