@page
@model PoetryManager.Web.Pages.Poems.CreateModel
@{
    ViewData["Title"] = "新建诗词";
}

<h2>新建诗词</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Poem.Title" class="form-label"></label>
                <input asp-for="Poem.Title" class="form-control" />
                <span asp-validation-for="Poem.Title" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Poem.Author" class="form-label"></label>
                    <input asp-for="Poem.Author" class="form-control" />
                    <span asp-validation-for="Poem.Author" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Poem.Dynasty" class="form-label"></label>
                    <input asp-for="Poem.Dynasty" class="form-control" placeholder="如：唐、宋、元" />
                    <span asp-validation-for="Poem.Dynasty" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Poem.Type" class="form-label"></label>
                    <select asp-for="Poem.Type" class="form-select"
                            asp-items="Html.GetEnumSelectList<PoetryManager.Web.Models.PoemType>()"></select>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Poem.Content" class="form-label"></label>
                <textarea asp-for="Poem.Content" class="form-control" rows="8"
                          placeholder="每句诗词请换行书写"></textarea>
                <span asp-validation-for="Poem.Content" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Poem.Translation" class="form-label"></label>
                <textarea asp-for="Poem.Translation" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Poem.Notes" class="form-label"></label>
                <textarea asp-for="Poem.Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label for="tags" class="form-label">标签</label>
                <input type="text" name="tags" id="tags" class="form-control"
                       placeholder="多个标签用逗号分隔，如：爱情,边塞,山水" />
                <div class="form-text">标签用于分类检索，如：爱国、山水、边塞、爱情、咏史</div>
            </div>

            <button type="submit" class="btn btn-primary">保存</button>
            <a asp-page="/Index" class="btn btn-secondary ms-2">取消</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
