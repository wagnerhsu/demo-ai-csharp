@page "{id:int}"
@model PoetryManager.Web.Pages.Poems.DetailsModel
@{
    ViewData["Title"] = Model.Poem.Title;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.Poem.Title</h2>
        <p class="text-muted mb-0">
            @Model.Poem.Author &nbsp;·&nbsp; @Model.Poem.Dynasty &nbsp;·&nbsp;
            @switch (Model.Poem.Type)
            {
                case PoetryManager.Web.Models.PoemType.Shi: <span class="badge bg-primary">诗</span> break;
                case PoetryManager.Web.Models.PoemType.Ci: <span class="badge bg-success">词</span> break;
                case PoetryManager.Web.Models.PoemType.Qu: <span class="badge bg-warning text-dark">曲</span> break;
            }
            @foreach (var pt in Model.Poem.PoemTags)
            {
                <span class="badge bg-secondary ms-1">@pt.Tag.Name</span>
            }
        </p>
    </div>
    <div>
        <a asp-page="/Poems/Edit" asp-route-id="@Model.Poem.Id" class="btn btn-outline-warning">编辑</a>
        <a asp-page="/Poems/Delete" asp-route-id="@Model.Poem.Id" class="btn btn-outline-danger ms-1">删除</a>
        <a asp-page="/Index" class="btn btn-outline-secondary ms-1">返回列表</a>
    </div>
</div>

<hr />

<div class="row">
    <div class="col-md-7">
        <h5>正文</h5>
        <pre class="poem-content">@Model.Poem.Content</pre>
    </div>
    @if (!string.IsNullOrEmpty(Model.Poem.Translation))
    {
        <div class="col-md-5">
            <h5>译文</h5>
            <p style="white-space: pre-wrap">@Model.Poem.Translation</p>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.Poem.Notes))
{
    <hr />
    <h5>注释</h5>
    <p style="white-space: pre-wrap">@Model.Poem.Notes</p>
}

<style>
    .poem-content {
        font-family: "KaiTi", "楷体", "SimSun", "宋体", serif;
        font-size: 1.15rem;
        line-height: 2.2;
        background: transparent;
        border: none;
        white-space: pre-wrap;
    }
</style>
