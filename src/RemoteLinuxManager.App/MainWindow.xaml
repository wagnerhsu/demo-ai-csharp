<ui:FluentWindow x:Class="RemoteLinuxManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Remote Linux Manager"
        Height="900"
        Width="1240"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Remote Linux Manager" />

        <Menu Grid.Row="1" Padding="8,2">
            <MenuItem Header="视图(_V)">
                <MenuItem Header="主题(_T)">
                    <MenuItem x:Name="MenuThemeDark"  Header="深色(_D)" Click="ThemeDark_Click"  IsCheckable="True" />
                    <MenuItem x:Name="MenuThemeLight" Header="浅色(_L)" Click="ThemeLight_Click" IsCheckable="True" IsChecked="True" />
                </MenuItem>
            </MenuItem>
        </Menu>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12,8,12,12">

                <!-- 连接配置 -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="连接配置" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="配置名称" />
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="4" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="主机" />
                            <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="端口" />
                            <TextBox Grid.Row="0" Grid.Column="5" Margin="4" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="用户名" />
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="4" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="认证方式" />
                            <ComboBox Grid.Row="1" Grid.Column="3" Margin="4"
                                      ItemsSource="{Binding AuthenticationTypes}"
                                      SelectedItem="{Binding AuthenticationType}" />
                            <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="连接状态" />
                            <StackPanel Grid.Row="1" Grid.Column="5" Orientation="Horizontal" Margin="4" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Fill" Value="#44BB44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未连接"/>
                                            <Setter Property="Foreground" Value="#FF4444"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Text" Value="已连接"/>
                                                    <Setter Property="Foreground" Value="#44BB44"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="密码" />
                            <ui:PasswordBox Grid.Row="2" Grid.Column="1" Margin="4"
                                            Password="{Binding Password, Mode=TwoWay}"
                                            PlaceholderText="密码" />
                            <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="私钥路径" />
                            <TextBox Grid.Row="2" Grid.Column="3" Margin="4" Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Text="私钥口令" />
                            <ui:PasswordBox Grid.Row="2" Grid.Column="5" Margin="4"
                                            Password="{Binding PrivateKeyPassphrase, Mode=TwoWay}"
                                            PlaceholderText="私钥口令" />

                            <ComboBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="4"
                                      ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfile}"
                                      DisplayMemberPath="Name" />
                            <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="4"
                                        Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button Margin="4" Content="加载配置" Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Symbol=ArrowClockwise20}"
                                           Command="{Binding LoadProfilesCommand}" />
                                <ui:Button Margin="4" Content="保存配置" Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Symbol=Save20}"
                                           Command="{Binding SaveProfileCommand}" />
                                <ui:Button Margin="4" Content="连接" Appearance="Primary"
                                           Icon="{ui:SymbolIcon Symbol=PlugConnected20}"
                                           Command="{Binding ConnectCommand}" />
                                <ui:Button Margin="4" Content="断开" Appearance="Secondary"
                                           Icon="{ui:SymbolIcon Symbol=PlugDisconnected20}"
                                           Command="{Binding DisconnectCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- 文件传输 -->
                <ui:Card Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="文件传输" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="260" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="4,4,4,2" FontWeight="SemiBold" Text="本地文件" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="4,4,4,2" FontWeight="SemiBold" Text="远程文件（连接后可用）" />

                            <TreeView Grid.Row="1" Grid.Column="0" Margin="4"
                                      x:Name="LocalTree"
                                      ItemsSource="{Binding LocalRoots}"
                                      SelectedItemChanged="LocalTree_SelectedItemChanged">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Name}" />
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <StackPanel Grid.Row="1" Grid.Column="1"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:Button Margin="4" Width="86" Content="上传"
                                           Icon="{ui:SymbolIcon Symbol=ArrowUpload20}"
                                           Appearance="Primary"
                                           Command="{Binding UploadCommand}" />
                                <ui:Button Margin="4" Width="86" Content="下载"
                                           Icon="{ui:SymbolIcon Symbol=ArrowDownload20}"
                                           Appearance="Secondary"
                                           Command="{Binding DownloadCommand}" />
                            </StackPanel>

                            <TreeView Grid.Row="1" Grid.Column="2" Margin="4"
                                      x:Name="RemoteTree"
                                      ItemsSource="{Binding RemoteRoots}"
                                      SelectedItemChanged="RemoteTree_SelectedItemChanged">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Name}" />
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="4,2,4,0"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       Text="{Binding SelectedLocalNode.FullPath, FallbackValue='未选择'}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Margin="4,2,4,0"
                                       FontSize="11" TextTrimming="CharacterEllipsis"
                                       Text="{Binding SelectedRemoteNode.FullPath, FallbackValue='未选择'}" />

                            <ProgressBar Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                         Height="18" Margin="4,6,4,0"
                                         Maximum="100" Value="{Binding TransferProgress}" />
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- 脚本执行 & 日志输出 -->
                <TabControl Margin="0,0,0,0">
                    <TabItem Header="脚本执行">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="执行模式" />
                            <ComboBox Grid.Row="0" Grid.Column="1" Margin="4"
                                      ItemsSource="{Binding ScriptInputTypes}"
                                      SelectedItem="{Binding ScriptInputType}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="远程工作目录" />
                            <TextBox Grid.Row="0" Grid.Column="3" Margin="4"
                                     Text="{Binding RemoteWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <ui:Button Grid.Row="0" Grid.Column="4" Margin="4" Content="执行脚本"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon Symbol=Play20}"
                                       Command="{Binding ExecuteScriptCommand}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Sudo 密码" />
                            <ui:PasswordBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="4"
                                            Password="{Binding SudoPassword, Mode=TwoWay}"
                                            PlaceholderText="Sudo 密码（可选）" />

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="本地脚本路径" />
                            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="4"
                                     Text="{Binding ScriptFilePath, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="内联脚本" />
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="4"
                                     Height="90" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding InlineScript, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="日志输出">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     x:Name="LogTextBox"
                                     MinHeight="260"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     KeyDown="LogTextBox_KeyDown"
                                     TextChanged="LogTextBox_TextChanged"
                                     Text="{Binding Logs}">
                                <TextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="复制" Command="ApplicationCommands.Copy" />
                                        <MenuItem Header="全选" Command="ApplicationCommands.SelectAll" />
                                        <Separator />
                                        <MenuItem Header="清空日志" Click="ClearLogs_Click" />
                                        <MenuItem Header="滚动到末尾" Click="ScrollToEnd_Click" />
                                        <Separator />
                                        <MenuItem Header="查找..." Click="ShowSearch_Click" InputGestureText="Ctrl+F" />
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>

                            <Border Grid.Row="1"
                                    x:Name="SearchBar"
                                    Visibility="Collapsed"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="8,4"
                                    Margin="0,4,0,0">
                                <DockPanel>
                                    <ui:Button DockPanel.Dock="Right"
                                               Icon="{ui:SymbolIcon Symbol=Dismiss20}"
                                               Appearance="Secondary"
                                               Width="32" Height="32" Margin="4,0,0,0"
                                               Click="CloseSearch_Click"
                                               ToolTip="关闭 (Esc)" />
                                    <TextBlock DockPanel.Dock="Right"
                                               x:Name="SearchResultLabel"
                                               VerticalAlignment="Center"
                                               Margin="6,0" MinWidth="54"
                                               FontSize="12" />
                                    <ui:Button DockPanel.Dock="Right"
                                               Content="下一个" Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Symbol=ChevronDown20}"
                                               Margin="2,0" Height="32"
                                               Click="FindNext_Click"
                                               ToolTip="下一个 (Enter / F3)" />
                                    <ui:Button DockPanel.Dock="Right"
                                               Content="上一个" Appearance="Secondary"
                                               Icon="{ui:SymbolIcon Symbol=ChevronUp20}"
                                               Margin="2,0" Height="32"
                                               Click="FindPrevious_Click"
                                               ToolTip="上一个 (Shift+Enter / Shift+F3)" />
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="查找:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBox x:Name="SearchInputBox"
                                             VerticalAlignment="Center"
                                             Height="28"
                                             KeyDown="SearchInputBox_KeyDown"
                                             TextChanged="SearchInputBox_TextChanged" />
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
