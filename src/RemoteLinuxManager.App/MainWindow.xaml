<Window x:Class="RemoteLinuxManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Remote Linux Manager"
        Height="1020"
        Width="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="连接配置" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="配置名称" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="4" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="主机" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="端口" />
                <TextBox Grid.Row="0" Grid.Column="5" Margin="4" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="用户名" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="4" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="认证方式" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          Margin="4"
                          ItemsSource="{Binding AuthenticationTypes}"
                          SelectedItem="{Binding AuthenticationType}" />
                <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="连接状态" />
                <TextBlock Grid.Row="1" Grid.Column="5" Margin="4" VerticalAlignment="Center" Text="{Binding IsConnected}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="密码" />
                <PasswordBox Grid.Row="2" Grid.Column="1" Margin="4" x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged" />
                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="私钥路径" />
                <TextBox Grid.Row="2" Grid.Column="3" Margin="4" Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Text="私钥口令" />
                <PasswordBox Grid.Row="2" Grid.Column="5" Margin="4" x:Name="PassphraseBox" PasswordChanged="PassphraseBox_PasswordChanged" />

                <ComboBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                          Margin="4"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberPath="Name" />
                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="4" Padding="12,6" Content="加载配置" Command="{Binding LoadProfilesCommand}" />
                    <Button Margin="4" Padding="12,6" Content="保存配置" Command="{Binding SaveProfileCommand}" />
                    <Button Margin="4" Padding="12,6" Content="连接" Command="{Binding ConnectCommand}" />
                    <Button Margin="4" Padding="12,6" Content="断开" Command="{Binding DisconnectCommand}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="文件传输" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="260" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="4,4,4,2" FontWeight="SemiBold" Text="本地文件" />
                <TextBlock Grid.Row="0" Grid.Column="2" Margin="4,4,4,2" FontWeight="SemiBold" Text="远程文件（连接后可用）" />

                <TreeView Grid.Row="1" Grid.Column="0" Margin="4"
                          x:Name="LocalTree"
                          ItemsSource="{Binding LocalRoots}"
                          SelectedItemChanged="LocalTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <StackPanel Grid.Row="1" Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Button Margin="4" Padding="8,6" Width="74" Content="→ 上传" Command="{Binding UploadCommand}" />
                    <Button Margin="4" Padding="8,6" Width="74" Content="← 下载" Command="{Binding DownloadCommand}" />
                </StackPanel>

                <TreeView Grid.Row="1" Grid.Column="2" Margin="4"
                          x:Name="RemoteTree"
                          ItemsSource="{Binding RemoteRoots}"
                          SelectedItemChanged="RemoteTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="4,2,4,0"
                           Foreground="Gray" FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedLocalNode.FullPath, FallbackValue='未选择'}" />
                <TextBlock Grid.Row="2" Grid.Column="2" Margin="4,2,4,0"
                           Foreground="Gray" FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedRemoteNode.FullPath, FallbackValue='未选择'}" />

                <ProgressBar Grid.Row="3"
                             Grid.Column="0"
                             Grid.ColumnSpan="3"
                             Height="18"
                             Margin="4,6,4,0"
                             Maximum="100"
                             Value="{Binding TransferProgress}" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="脚本执行" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="执行模式" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Margin="4"
                          ItemsSource="{Binding ScriptInputTypes}"
                          SelectedItem="{Binding ScriptInputType}" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="远程工作目录" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding RemoteWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0" Grid.Column="4" Margin="4" Padding="12,6" Content="执行脚本" Command="{Binding ExecuteScriptCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Sudo 密码" />
                <PasswordBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="4" x:Name="SudoPasswordBox" PasswordChanged="SudoPasswordBox_PasswordChanged" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="本地脚本路径" />
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="4" Text="{Binding ScriptFilePath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="内联脚本" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         Grid.ColumnSpan="4"
                         Margin="4"
                         Height="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding InlineScript, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="日志输出">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         x:Name="LogTextBox"
                         Margin="8,8,8,0"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         KeyDown="LogTextBox_KeyDown"
                         TextChanged="LogTextBox_TextChanged"
                         Text="{Binding Logs}">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制" Command="ApplicationCommands.Copy" />
                            <MenuItem Header="全选" Command="ApplicationCommands.SelectAll" />
                            <Separator />
                            <MenuItem Header="清空日志" Click="ClearLogs_Click" />
                            <MenuItem Header="滚动到末尾" Click="ScrollToEnd_Click" />
                            <Separator />
                            <MenuItem Header="查找..." Click="ShowSearch_Click" InputGestureText="Ctrl+F" />
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>

                <Border Grid.Row="1"
                        x:Name="SearchBar"
                        Visibility="Collapsed"
                        Background="#F0F0F0"
                        BorderBrush="#CCCCCC"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="✕" Width="26" Height="26"
                                Margin="4,0,0,0"
                                Click="CloseSearch_Click"
                                ToolTip="关闭 (Esc)" />
                        <TextBlock DockPanel.Dock="Right"
                                   x:Name="SearchResultLabel"
                                   VerticalAlignment="Center"
                                   Margin="6,0" MinWidth="54"
                                   Foreground="Gray" FontSize="12" />
                        <Button DockPanel.Dock="Right"
                                Content="↓ 下一个" Padding="8,2" Margin="2,0"
                                Click="FindNext_Click"
                                ToolTip="下一个 (Enter / F3)" />
                        <Button DockPanel.Dock="Right"
                                Content="↑ 上一个" Padding="8,2" Margin="2,0"
                                Click="FindPrevious_Click"
                                ToolTip="上一个 (Shift+Enter / Shift+F3)" />
                        <TextBlock DockPanel.Dock="Left"
                                   Text="查找:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                        <TextBox x:Name="SearchInputBox"
                                 VerticalAlignment="Center"
                                 Height="24"
                                 KeyDown="SearchInputBox_KeyDown"
                                 TextChanged="SearchInputBox_TextChanged" />
                    </DockPanel>
                </Border>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
