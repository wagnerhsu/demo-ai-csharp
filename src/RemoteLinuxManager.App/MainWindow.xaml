<Window x:Class="RemoteLinuxManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Remote Linux Manager"
        Height="860"
        Width="1200">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="连接配置" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="配置名称" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="4" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="主机" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Text="端口" />
                <TextBox Grid.Row="0" Grid.Column="5" Margin="4" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="用户名" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="4" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="认证方式" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          Margin="4"
                          ItemsSource="{Binding AuthenticationTypes}"
                          SelectedItem="{Binding AuthenticationType}" />
                <TextBlock Grid.Row="1" Grid.Column="4" VerticalAlignment="Center" Text="连接状态" />
                <TextBlock Grid.Row="1" Grid.Column="5" Margin="4" VerticalAlignment="Center" Text="{Binding IsConnected}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="密码" />
                <PasswordBox Grid.Row="2" Grid.Column="1" Margin="4" x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged" />
                <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Text="私钥路径" />
                <TextBox Grid.Row="2" Grid.Column="3" Margin="4" Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2" Grid.Column="4" VerticalAlignment="Center" Text="私钥口令" />
                <PasswordBox Grid.Row="2" Grid.Column="5" Margin="4" x:Name="PassphraseBox" PasswordChanged="PassphraseBox_PasswordChanged" />

                <ComboBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                          Margin="4"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding SelectedProfile}"
                          DisplayMemberPath="Name" />
                <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="4" Padding="12,6" Content="加载配置" Command="{Binding LoadProfilesCommand}" />
                    <Button Margin="4" Padding="12,6" Content="保存配置" Command="{Binding SaveProfileCommand}" />
                    <Button Margin="4" Padding="12,6" Content="连接" Command="{Binding ConnectCommand}" />
                    <Button Margin="4" Padding="12,6" Content="断开" Command="{Binding DisconnectCommand}" />
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="文件传输" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="上传本地路径" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="4" Text="{Binding LocalUploadPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="上传远程路径" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding RemoteUploadPath, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0" Grid.Column="4" Margin="4" Padding="12,6" Content="上传" Command="{Binding UploadCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="下载远程路径" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="4" Text="{Binding RemoteDownloadPath, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Text="下载本地路径" />
                <TextBox Grid.Row="1" Grid.Column="3" Margin="4" Text="{Binding LocalDownloadPath, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Grid.Column="4" Margin="4" Padding="12,6" Content="下载" Command="{Binding DownloadCommand}" />

                <ProgressBar Grid.Row="2"
                             Grid.Column="0"
                             Grid.ColumnSpan="5"
                             Height="18"
                             Margin="4"
                             Maximum="100"
                             Value="{Binding TransferProgress}" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="脚本执行" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="执行模式" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Margin="4"
                          ItemsSource="{Binding ScriptInputTypes}"
                          SelectedItem="{Binding ScriptInputType}" />
                <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Text="远程工作目录" />
                <TextBox Grid.Row="0" Grid.Column="3" Margin="4" Text="{Binding RemoteWorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="0" Grid.Column="4" Margin="4" Padding="12,6" Content="执行脚本" Command="{Binding ExecuteScriptCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="本地脚本路径" />
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="4" Text="{Binding ScriptFilePath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="内联脚本" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Grid.ColumnSpan="4"
                         Margin="4"
                         Height="90"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding InlineScript, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Header="日志输出">
            <TextBox Margin="8"
                     FontFamily="Consolas"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True"
                     Text="{Binding Logs}" />
        </GroupBox>
    </Grid>
</Window>
